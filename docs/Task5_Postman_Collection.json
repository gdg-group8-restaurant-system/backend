  "item": [
    {
      "name": "1. Setup & Auth",
      "item": [
        {
          "name": "Student Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status expects 201\", function () { pm.response.to.have.status(201); });",
                  "const response = pm.response.json();",
                  "if (response.user) {",
                  "    pm.collectionVariables.set(\"student_id\", response.user.id);",
                  "}",
                  "if (response.accessToken) {",
                  "    pm.collectionVariables.set(\"student_token\", response.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.variables.set('dyn_student_phone', '09' + Math.floor(10000000 + Math.random() * 90000000));",
                  "pm.variables.set('dyn_student_id', 'ETS' + Math.floor(1000 + Math.random() * 9000) + '/16');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Student\",\n  \"studentId\": \"{{dyn_student_id}}\",\n  \"phoneNumber\": \"{{dyn_student_phone}}\",\n  \"password\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "Admin Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status expects 201\", function () { pm.response.to.have.status(201); });",
                  "const response = pm.response.json();",
                  "if (response.accessToken) {",
                  "    pm.collectionVariables.set(\"admin_token\", response.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.variables.set('dyn_admin_phone', '09' + Math.floor(10000000 + Math.random() * 90000000));",
                  "pm.variables.set('dyn_admin_id', 'ETS' + Math.floor(1000 + Math.random() * 9000) + '/16');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"System Admin\",\n  \"studentId\": \"{{dyn_admin_id}}\",\n  \"phoneNumber\": \"{{dyn_admin_phone}}\",\n  \"password\": \"admin123\",\n  \"role\": \"admin\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          }
        }
      ]
    },
