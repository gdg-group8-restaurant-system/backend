          "name": "Admin: Verify Student",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/users/{{student_id}}/verify",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "users",
                "{{student_id}}",
                "verify"
              ]
